# Bu dosyayı ".env" olarak kopyalayın ve değerleri kendi ortamınıza göre doldurun.
# Gerçek şifre, JWT anahtarı veya API anahtarlarını repoya asla eklemeyin.

# Sunucu
PORT=4000
NODE_ENV=development
# Üretim: ters proxy (nginx) arkasında istemci IP ve HTTPS için
# TRUST_PROXY=1
# FORCE_HTTPS=true
# Doğrudan Node üzerinde TLS (ikisi de doluysa HTTPS dinler)
# HTTPS_KEY_PATH=/path/to/privkey.pem
# HTTPS_CERT_PATH=/path/to/fullchain.pem
FRONTEND_ORIGIN=http://localhost:5173
# Google OAuth sonrası /login-success ve /login-error adresleri (varsayılan: FRONTEND_ORIGIN).
# OAUTH_FRONTEND_REDIRECT_ORIGIN=https://pdfplatform.app
# Tarayıcı SPA "Google ile devam" tıklayınca ?frontend_origin=<mevcut_origin> gönderir; izin verilen kökler FRONTEND_ORIGIN + aşağıdaki allowlist ve (development veya bayrak ile) localhost kökleridir.
# OAUTH_ALLOWED_REDIRECT_ORIGINS=https://staging.example.com,https://preview-xxx.vercel.app
# Üretim .env ile localhost testi: OAUTH_ALLOW_LOOPBACK_REDIRECTS=true
# OAUTH_ALLOW_LOOPBACK_REDIRECTS=false
# Kimlik API’sinin dışarıdan erişilen kökü; e-posta doğrulama linki: {APP_BASE_URL}/api/auth/verify-email?token=...
APP_BASE_URL=http://localhost:4000
# iyzico ödeme geri dönüşü (POST /api/payments/callback) — yerelde Node API kökü ile aynı olmalı; boşsa APP_BASE_URL kullanılır.
PAYMENT_CALLBACK_BASE_URL=http://localhost:4000
# Yerel Chrome’da SPA (localhost:5173) varken OAuth hâlâ üretime gidiyorsa: tarayıcı kimlik isteklerini yerel API’ye yönlendirmelidir.
# `web/frontend/.env` içinde NEXT_PUBLIC_API_URL / VITE_SAAS_API_BASE boş olmalı veya Vite proxy kullanılmalı; aksi halde istekler üretim API’ye gider.
COOKIE_DOMAIN=

# Veritabanı — Prisma SQLite. Dosya `web/api/prisma/` içinde oluşturulur (`./dev.db` şemanın dizinine göredir).
# PostgreSQL kurmanız gerekmez; boş bırakılırsa uygulama `file:./dev.db` kullanır.
DATABASE_URL="file:./dev.db"

# Küresel bakım (kimlik API + `/api/public/runtime`): true + API yeniden dağıtım. Yerel SPA için ayrıca `web/frontend` `VITE_MAINTENANCE_MODE` kullanın.
# MAINTENANCE_MODE=false

# JWT: en az 32 karakter, üretimde güçlü rastgele değerler kullanın (asla örnek değeri üretimde kullanmayın).
# Not: Bu projede tek bir JWT_SECRET yok; erişim ve yenileme için iki ayrı anahtar vardır.
JWT_ACCESS_SECRET=local-dev-replace-with-random-at-least-32-chars-secret-one
JWT_REFRESH_SECRET=local-dev-replace-with-random-at-least-32-chars-secret-two

ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
EMAIL_VERIFICATION_TTL_HOURS=24

# E-posta — Gmail: normal şifre ÇALIŞMAZ. Google Hesabı → Güvenlik → 2 Adımlı Doğrulama → Uygulama şifreleri.
# 16 karakterlik uygulama şifresini buraya yazın (boşluksuz).
EMAIL_USER=your-account@gmail.com
EMAIL_PASS=your-16-char-app-password

# Gmail SMTP (varsayılanlar env şemasında da aynı; açıkça yazmak isterseniz:)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# Port 465 kullanıyorsanız true yapın; 587 için false (STARTTLS).
SMTP_SECURE=false

SMTP_FROM_NAME=PDF PLATFORM

# Yönetici gelen kutusu (kayıt bildirimleri vb.)
ADMIN_EMAIL=.........@gmail.com
# İletişim formu (POST /api/contact) — belirtilmezse nbglobalstudio@gmail.com kullanılır
# CONTACT_TO_EMAIL=nbglobalstudio@gmail.com

# İlk kurulumda tek seferlik yönetici hesabı (ikisi de doluysa oluşturulur; boş bırakılabilir)
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# Google OAuth (web: "Google ile devam et") — boş bırakılırsa devre dışı
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxx

# iyzico (PRO/Business ödeme) — değerler Kimlik API sürecinde okunur: web/api/.env
# Üçü de dolu değilse POST /api/payment/create 503 döner.
# iyzico paneli: https://merchant.iyzipay.com/ — API anahtarları bölümünden alın.
# Sandbox URI: https://sandbox-api.iyzipay.com  |  Üretim: https://api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_URI=https://sandbox-api.iyzipay.com
# (İsteğe bağlı) Checkout’ta test alıcı T.C. / GSM — dokümana göre güncelleyin
# IYZICO_BUYER_IDENTITY_NUMBER=74300864791
# IYZICO_BUYER_GSM=+905350000000

# Kredi paketi (credit-checkout): iyzico yerine anında (fake) onay — test veya anahtar yokken
# Tüm IYZICO_* boşken veya NODE_ENV=development (aşağıdaki bayrak false iken) fake kullanılır.
# Staging’de kasten fake: CREDIT_CHECKOUT_USE_FAKE=true
# Geliştirmede gerçek iyzico denemek: CREDIT_CHECKOUT_IYZICO_IN_DEV=true
# CREDIT_CHECKOUT_USE_FAKE=false
# CREDIT_CHECKOUT_IYZICO_IN_DEV=false

# ─── Stripe (yeni fatura sistemi) ────────────────────────────────────────────
# Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs (Dashboard → Products → Prices → Copy ID)
STRIPE_PRICE_PLUS_MONTHLY_TRY=price_...
STRIPE_PRICE_PLUS_MONTHLY_USD=price_...
STRIPE_PRICE_PRO_YEARLY_TRY=price_...
STRIPE_PRICE_PRO_YEARLY_USD=price_...
STRIPE_PRICE_BUSINESS_MONTHLY_TRY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY_USD=price_...
STRIPE_PRICE_BUSINESS_YEARLY_TRY=price_...
STRIPE_PRICE_BUSINESS_YEARLY_USD=price_...

# ─── BullMQ / Redis (toplu işlem kuyruğu) ────────────────────────────────────
# Redis bağlantısı (upstash veya yerel): REDIS_URL=redis://localhost:6379
# REDIS_URL=

# ─── Coğrafi konum (ülke tespiti için) ───────────────────────────────────────
# GEOIP_API_KEY=

# Dosya günlüğü
LOG_FILE_PATH=logs/nb-pdf-platform-api.log
LOG_FILE_ENABLED=true

# Admin medya yükleme: local (uploads/media + /api/media/files/…) veya s3
# MEDIA_STORAGE=local
# MEDIA_STORAGE=s3
# MEDIA_PUBLIC_BASE_URL=https://your-bucket.s3.eu-central-1.amazonaws.com
# S3_BUCKET=your-bucket
# S3_REGION=eu-central-1
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# MinIO veya özel uç: S3_ENDPOINT=http://127.0.0.1:9000  ve  S3_FORCE_PATH_STYLE=true

# ─── Üretim Güvenlik Notları ──────────────────────────────────────────────────
# 1. NODE_ENV=production yapın (stack trace'leri gizler, Helmet CSP devreye girer).
# 2. JWT_ACCESS_SECRET ve JWT_REFRESH_SECRET en az 64 karakter rastgele string olmalı.
#    Üretmek için: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 3. IYZICO_SECRET_KEY ve IYZICO_API_KEY üretim değerleri olmalı (sandbox değil).
# 4. DATABASE_URL SQLite yerine PostgreSQL URL'i olmalı.
# 5. TRUST_PROXY=1 (nginx/Caddy arkasındaysa) ve FORCE_HTTPS=true yapın.
# 6. LOG_FILE_PATH /var/log/nb-pdf-platform/ gibi kalıcı bir yol olmalı.
