generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  BUSINESS
}

enum Language {
  tr
  en
}

enum UserRole {
  USER
  ADMIN
}

/// İndirme kanıtı: SUCCESS yalnızca tarayıcı ACK sonrası.
enum DownloadLogStatus {
  PENDING
  SUCCESS
  FAILED
}

enum AuthProvider {
  local
  google
}

enum SubscriptionStatus {
  none
  active
  past_due
  canceled
  incomplete
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  firstName    String?        @map("first_name")
  lastName     String?        @map("last_name")
  name         String?
  /// Google "sub" (OpenID); yalnızca Google ile kayıtlı kullanıcılar için dolu
  googleId     String?        @unique
  avatar       String?
  passwordHash String?
  authProvider AuthProvider   @default(local)
  role         UserRole       @default(USER)
  isVerified   Boolean        @default(false)
  verifiedAt   DateTime?
  /// Kayıt sonrası e-posta doğrulama belirteci (düz metin); doğrulama sonrası null olur.
  verificationToken String?
  plan         Plan           @default(FREE)
  /// Ücretli abonelik bitişi; ücretsiz veya süresiz için null olabilir.
  subscriptionExpiry DateTime? @map("subscription_expiry")
  preferredLanguage Language  @default(en)
  /// İlk kez günlük ücretsiz kota aşıldığında (post-limit op veya kota üstü); dönüşüm analitiği.
  freeLimitFirstExceededAt DateTime? @map("free_limit_first_exceeded_at")
  /// Ömür boyu tamamlanan PDF işlemi (web + masaüstü); monetizasyon / adaptif gecikme.
  totalOperationsCount     Int            @default(0) @map("total_operations_count")
  /// Ömür boyu gecikmeli assert/authorize sayısı (FREE sürtünme).
  totalThrottleEventsCount Int            @default(0) @map("total_throttle_events_count")
  /// JSON: { "split": n, "merge": n, ... } en çok kullanılan araçlar.
  toolUsageCountsJson      String         @default("{}") @map("tool_usage_counts_json")
  /// Gecikme sonrası veya kayıt yanıtında kaç kez yükseltme CTA gösterildi (dönüşüm).
  totalUpgradeCtaImpressionsCount Int     @default(0) @map("total_upgrade_cta_impressions_count")
  /// Coarse geo fields for admin analytics (optional; may be set from IP / profile).
  country      String?
  city         String?
  /// Billing / checkout (iyzico): set from ProfileCompletionModal before payment.
  phone                String?  @map("phone")
  billingAddressLine   String?  @map("billing_address_line")
  billingPostalCode    String?  @map("billing_postal_code")
  /// Throttle for automated low-credit marketing email (nudge at most per cooldown).
  lowCreditNudgeAt DateTime? @map("low_credit_nudge_at")
  /// Son “çıkış niyeti” %10 kredi indiriminin uygulandığı zaman (30 gün cooldown).
  lastExitIntentCreditDiscountAt DateTime? @map("last_exit_intent_credit_discount_at")
  /// Prepaid credit balance; decremented atomically when a tool is used without an active subscription.
  credit_balance       Int     @default(0)
  /// Payment provider subscription status; app-layer union: none | active | past_due | canceled | incomplete.
  subscription_status SubscriptionStatus @default(none)
  /// Stripe customer id (nullable; populated on first Stripe interaction).
  stripe_customer_id   String? @unique
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  refreshTokens RefreshToken[]
  dailyUsages  DailyUsage[]
  verificationTokens EmailVerificationToken[]
  pageViews    PageView[]
  clientErrorLogs ClientErrorLog[]
  desktopDevices DesktopDevice[]
  paymentCheckouts PaymentCheckout[]
  creditPackCheckouts CreditPackCheckout[]
  passwordResetCodes PasswordResetCode[]
  creditTransactions CreditTransaction[]
  downloadLogs     DownloadLog[]
  couponUses       CouponUse[]
  entitlement        UserEntitlement?
  /// Admin actions logged to AdminAuditLog; userId on log row references this user when the actor is known.
  adminAuditLogs     AdminAuditLog[] @relation("AdminAuditActor")

  @@index([stripe_customer_id])
  @@index([country])
}

/// E-posta ile gönderilen 6 haneli şifre sıfırlama kodu (hash saklanır).
model PasswordResetCode {
  id         String    @id @default(cuid())
  codeHash   String    @map("code_hash")
  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  userId     String    @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

/// iyzico ödeme oturumu; plan yükseltmesi yalnızca completed + doğrulanmış retrieve sonrası uygulanır.
model PaymentCheckout {
  id               String    @id @default(cuid())
  conversationId   String    @unique
  /// SHA-256(iyzico checkout `token`) after initialize — used when retrieve omits conversationId.
  iyzicoTokenHash  String?   @unique @map("iyzico_token_hash")
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan             Plan
  status           String    @default("pending")
  /// priceTry ileride eklenecek provider, stripeSessionId, stripeEventId
  priceTry         String
  /// ISO 4217: TRY | USD | EUR — hangi para birimiyle tahsil edildi (muhasebe).
  paymentCurrency  String         @default("TRY") @map("payment_currency")
  /// Subscription length applied on successful payment (30 = monthly, 365 = annual).
  subscriptionDays Int       @default(30) @map("subscription_days")
  createdAt        DateTime  @default(now())
  completedAt      DateTime?

  @@index([userId])
  @@index([status])
}

model RefreshToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DailyUsage {
  id              String   @id @default(cuid())
  usageDate       String
  operationsCount Int      @default(0)
  /// Ops today after free daily allowance (monetization / analytics).
  postLimitExtraOps Int    @default(0) @map("post_limit_extra_ops")
  /// Bugün kota aşımı sonrası kaç kez gecikmeli assert/authorize uygulandı (dönüşüm / tekrarlayan gecikme).
  postLimitThrottleCount Int @default(0) @map("post_limit_throttle_count")
  lastFeatureKey  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, usageDate])
  @@index([userId])
}

/// Özel indirim kodu (hızlı kredi satın alma).
model Coupon {
  id                String   @id @default(cuid())
  /// Büyük harf normalize, benzersiz.
  code              String   @unique
  discountPercent   Int
  isActive          Boolean  @default(true)
  /// Kullanıcı başına maks. kullanım.
  usageLimitPerUser Int      @default(1)
  createdAt         DateTime @default(now()) @map("created_at")
  uses              CouponUse[]
  creditCheckouts  CreditPackCheckout[]

  @@map("coupons")
}

/// Kullanım kaydı: limit sayımı için.
model CouponUse {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  couponId  String   @map("coupon_id")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)

  @@index([userId, couponId])
  @@index([couponId])
  @@map("coupon_uses")
}

/// Kredi paketi: sahte ödeme veya iyzico (conversationId) ile eşleşir.
model CreditPackCheckout {
  id                String    @id @default(cuid())
  conversationId    String    @unique
  /// SHA-256(iyzico checkout `token`) after initialize — used when retrieve omits conversationId.
  iyzicoTokenHash   String?   @unique @map("iyzico_token_hash")
  userId            String
  product           String
  basePriceTry      String    @map("base_price_try")
  finalPriceTry     String    @map("final_price_try")
  /// TRY | USD | EUR — tahsilat para birimi (price alanları bu birimdeki tutar stringleri).
  paymentCurrency   String     @default("TRY") @map("payment_currency")
  credits           Int
  status            String    @default("pending")
  couponId          String?   @map("coupon_id")
  exitIntentApplied Boolean   @default(false) @map("exit_intent_applied")
  createdAt         DateTime  @default(now()) @map("created_at")
  completedAt       DateTime? @map("completed_at")
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupon            Coupon?   @relation(fields: [couponId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@map("credit_pack_checkouts")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PageView {
  id        String   @id @default(cuid())
  view      String
  path      String
  sessionId String
  language  Language?
  referrer  String?
  userAgent String?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([view])
  @@index([userId])
}

model ClientErrorLog {
  id        String   @id @default(cuid())
  level     String
  message   String
  source    String?
  stack     String?
  url       String?
  userAgent String?
  language  Language?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([level])
  @@index([userId])
}

model DesktopDevice {
  id         String   @id @default(cuid())
  deviceHash String
  firstSeenAt DateTime @default(now())
  lastSeenAt DateTime @default(now())
  blockedAt  DateTime?
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceHash])
  @@index([userId])
}

/// Admin-editable key/value (JSON string) for CMS, site settings, marketing copy drafts.
/// Yönetici tarafından engellenen (normalize) e-postalar; yeni kayıt ve OAuth ile hesap açılamaz.
model BlockedEmail {
  email     String   @id
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("blocked_emails")
}

model SiteSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Typed global site configuration (singleton row: id = 1). Complements `SiteSetting` key/value for admin UI.
/// Fields: site name, logo, global maintenance, SEO. Managed from Admin; no code deploy required for copy changes.
model AppSettings {
  id                    Int     @id @default(1)
  siteName              String  @default("NB PDF") @map("site_name")
  logoUrl               String? @map("logo_url")
  globalMaintenanceMode Boolean @default(false) @map("global_maintenance_mode")
  seoTitle              String? @map("seo_title")
  seoDescription        String? @map("seo_description")
  seoKeywords           String? @map("seo_keywords")
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

/// Files uploaded from the admin panel; served from `/api/media/files/:storageKey`.
model MediaAsset {
  id           String   @id @default(cuid())
  storageKey   String   @unique
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  byteSize     Int      @map("byte_size")
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([createdAt])
}

/// Admin actions (who changed what). `userId` is the admin user id (equivalent to product term "adminId").
model AdminAuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now()) @map("created_at")
  userId     String?  @map("user_id")
  userEmail  String   @map("user_email")
  action     String
  targetKey  String?  @map("target_key")
  summary    String
  metaJson   String?  @map("meta_json")
  adminActor User?    @relation("AdminAuditActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([userId])
  @@map("admin_audit_logs")
}

/// Snapshot of a SiteSetting value *before* each admin write (for rollback).
model SettingRevision {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now()) @map("created_at")
  scope        String
  userId       String?  @map("user_id")
  userEmail    String   @map("user_email")
  summary      String?
  previousJson String   @map("previous_json")

  @@index([scope, createdAt])
  @@map("setting_revisions")
}

model CreditTransaction {
  id        String   @id @default(cuid())
  userId    String
  type      String   // consume | refund | bonus | admin_add
  amount    Int
  toolId    String?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserEntitlement {
  id        String @id @default(cuid())
  userId    String @unique

  canUseTools Boolean @default(false)
  canExport   Boolean @default(false)
  maxCredits  Int

  updatedAt DateTime @updatedAt

  user      User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Tool configuration (id = toolId). `cost` is the credit cost per use (UI may label it "creditCost").
/// Flags support per-tool maintenance and catalog visibility without redeploying code.
model ToolRegistry {
  id        String @id
  strategy  String
  cost      Int
  isVisible         Boolean  @default(true) @map("is_visible")
  isMaintenanceMode Boolean  @default(false) @map("is_maintenance_mode")
  /// Default for existing rows on migrate; then auto-updated on tool config changes.
  updatedAt         DateTime @default(now()) @updatedAt
}

/// Uygulama katmanı indirme denemesi: IP/UA ve araç; başarı sadece client ACK ile.
/// Operasyonel tutma: sorgularda createdAt &gt; now - 1y (arşiv/cron ayrı).
model DownloadLog {
  id         String            @id @default(cuid())
  userId     String            @map("user_id")
  resultId   String?           @map("result_id")
  toolId     String            @map("tool_id")
  clientIp   String?           @map("client_ip")
  userAgent  String?           @map("user_agent")
  status     DownloadLogStatus @default(PENDING)
  ackedAt    DateTime?         @map("acked_at")
  createdAt  DateTime          @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@map("download_logs")
}
