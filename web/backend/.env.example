# PDF API (FastAPI) ortam değişkenleri
# Bu dosyayı ".env" olarak kopyalayın.

PDF_API_HOST=127.0.0.1
PDF_API_PORT=8000

# CORS: virgülle ayrılmış izin verilen kökenler (boşsa localhost/127.0.0.1 kabul edilir)
# CORS_ORIGINS=https://pdfplatform.app

# Sentry hata izleme — https://sentry.io adresinden ücretsiz DSN alın.
# Boş bırakılırsa Sentry devre dışı kalır.
# SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX

# Ortam adı (Sentry etiketlemesi için)
ENVIRONMENT=production

# ─── S3-Uyumlu Nesne Depolama (PDF Sonuçları) ────────────────────────────────
# Boş bırakılırsa yerel disk (tmp/results/) kullanılır — geliştirme için uygundur.
# Üretimde yatay ölçekleme için AWS S3 veya Cloudflare R2 kullanın.
#
# Cloudflare R2: cloudflare.com → R2 → bucket oluştur → API Tokens → R2 Token al
#   S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#   S3_REGION=auto
#
# AWS S3: IAM → User → S3 izinleri ver → Access Key oluştur
#   S3_REGION=eu-central-1
#   (S3_ENDPOINT boş bırakın)
#
# S3_BUCKET=nb-pdf-results
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
#
# Presigned URL geçerlilik süresi (saniye, varsayılan 3600 = 1 saat)
# S3_PRESIGN_TTL_SECONDS=3600
#
# S3 yaşam döngüsü kuralı için TTL (saat, varsayılan 24) — bucket'ta lifecycle kural ekleyin!
# S3_RESULT_TTL_HOURS=24
