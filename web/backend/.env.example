# Bu dosyayı `.env` olarak kopyalayın (veya Node kimlik API ile aynı klasör düzeni).

# Node web/api/.env ile AYNI JWT_ACCESS_SECRET (en az 32 karakter)
JWT_ACCESS_SECRET=replace-with-same-secret-as-node-api-min-32-chars

# FastAPI bu projede SQLite üzerinden Node’un kullanıcı tablosunu okur (bkz. web/backend/app/config.py).
# Varsayılan Node SQLite dosyası: web/api/prisma/dev.db (NODE kimlik API ile aynı).
# SQLITE_DB_PATH=C:\path\to\NB_PDF_TOOLS\web\api\prisma\dev.db

# Alternatif: DATABASE_URL (file:...) — backend çalışma dizinine göre göreceli yol
# DATABASE_URL=file:../api/prisma/dev.db

# Üretim: tarayıcı kökeni (virgülle ayırın). Boşsa yalnızca localhost/127.0.0.1:any port kabul edilir.
# CORS_ORIGINS=https://app.example.com,https://www.example.com

# --- Ölçek (yoğun eşzamanlı PDF işleri, madde 8–9) ---
# PDF işleri için özel thread havuzu + eşzamanlılık tavanı (işlem başına).
# Toplam kabaca: uvicorn_worker_sayısı × PDF_CPU_MAX_IN_FLIGHT eşzamanlı PDF görevi.
# PDF_CPU_WORKERS=16
# PDF_CPU_MAX_IN_FLIGHT=16
# Kuyrukta slot beklerken üst sınır (saniye); aşılınca HTTP 503 + Retry-After.
# PDF_CPU_QUEUE_WAIT_SEC=300
# 503 yanıtında Retry-After başlığı (saniye).
# PDF_CPU_RETRY_AFTER_SEC=60
# SlowAPI varsayılan IP limiti (ör. 120/minute). Çok worker’da limiter süreç başına ayrıdır;
# tutarlı dağıtık limit için SlowAPI storage_uri veya API gateway kullanın.
# RATE_LIMIT_DEFAULT=120/minute
# Üretimde CDN/LB arkasında gerçek istemci IP’si için: TRUST_PROXY=1

# Uvicorn süreç sayısı (run-pdf-api.mjs / uvicorn CLI). >1 iken --reload kapalı olur.
# PDF_UVICORN_WORKERS=4

# Önizleme kahraman PNG üretimi (routes ile ayrı tavan; thread_pool’dan bağımsız).
# PREVIEW_HERO_MAX_CONCURRENT=2

# --- Güvenlik / Loglama ---
# Tek bir PDF işleminin maksimum çalışma süresi (saniye). Aşılınca 503 döner.
# PDF_OPERATION_TIMEOUT_SEC=120

# Log formatı: json (üretim) veya text (geliştirme). Varsayılan: json (prod), text (dev).
# LOG_FORMAT=json

# Log seviyesi: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# Faturalama (Billing)
# ---------------------------------------------------------------------------

# Hangi provider kullanılacak: mock (geliştirme) | parasut | birfatura
BILLING_PROVIDER=mock

# Paraşüt OAuth2 + şirket bilgileri (BILLING_PROVIDER=parasut iken gerekli)
# PARASUT_CLIENT_ID=
# PARASUT_CLIENT_SECRET=
# PARASUT_USERNAME=
# PARASUT_PASSWORD=
# PARASUT_COMPANY_ID=

# BirFatura (BILLING_PROVIDER=birfatura iken gerekli)
# BirFatura panelinde Mağaza Ayarları > Özel Entegrasyon > API Şifresi alanına gireceğiniz token
# BIRFATURA_API_TOKEN=your-guid-token-here
# BirFatura'nın fatura callback'ini bekleme süresi (saniye; varsayılan 600 = 10 dakika)
# BIRFATURA_POLL_TIMEOUT_SEC=600
# BirFatura polling kontrol aralığı saniyesi (varsayılan 15)
# BIRFATURA_POLL_INTERVAL_SEC=15

# E-posta backend: smtp veya sendgrid
EMAIL_BACKEND=smtp
EMAIL_FROM=billing@yourapp.com
EMAIL_FROM_NAME=YourApp
COMPANY_NAME=YourApp

# SMTP ayarları (EMAIL_BACKEND=smtp)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=

# SendGrid (EMAIL_BACKEND=sendgrid)
# SENDGRID_API_KEY=
