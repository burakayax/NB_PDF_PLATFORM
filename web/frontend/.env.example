# Bu dosyayı ".env" olarak kopyalayın. Yerelde `.env.local` kullanırsanız aynı anahtarları oraya da yazabilirsiniz (commit edilmemeli).
#
# Yerel geliştirme (Docker yok): Vite http://localhost:5173 — Kimlik API http://localhost:4000 — FastAPI PDF http://localhost:8000
#
# Arama motorları: uzun süreli geliştirme / Vercel önizlemesinde indekslemeyi kapatır (robots.txt + meta noindex).
# Canlı yayına çıkarken: false yapın ve yeniden build edin.
VITE_BLOCK_SEARCH_INDEXING=true
#
# NEXT_PUBLIC_API_URL — Kimlik API (Express) kök adresi.
# Yerelde OAuth’un her zaman yerel kimlik API’sine gitmesi için BOŞ bırakın (Vite /api proxy).
# pdfplatform’a gömülü bir üretim URL’si kullanılırsa OAuth üretimden döner; özel olarak uzak API
# denemek için: VITE_USE_REMOTE_SAAS_IN_DEV=true
# VITE_USE_REMOTE_SAAS_IN_DEV=false
# Öncelik: NEXT_PUBLIC_API_URL > VITE_SAAS_API_BASE (saasBase.ts).
#
# Geliştirmede React tarafında import.meta.env.DEV true iken PDF çağrıları göreli `/api/...` ile Vite proxy üzerinden gider (varsayılan hedef 127.0.0.1:8000).
# Yalnızca `web/frontend` içinde `npm run dev` çalıştırırsanız FastAPI başlamaz → PDF araçları takılır.
# Çözüm: proje kökünde `npm run dev` VEYA burada `npm run dev:with-pdf-api` (PDF API + Vite birlikte).
#
# Aşağıdaki VITE_API_BASE genelde üretim derlemesi içindir; yerel Vite dev'de pdfApi kökü için kullanılmaz (bkz. api.ts getPdfApiBase).
#
# VITE_SAAS_API_BASE: Geriye dönük uyumluluk; NEXT_PUBLIC_API_URL yoksa kullanılır.
#   Geliştirmede BOŞ — Vite proxy kullanılır.
#   `http://localhost:4000` yazmayın: tarayıcı doğrudan :4000’e gider; UI API’den önce açılınca sık bağlantı hatası oluşur.
# VITE_SAAS_PROXY_TARGET: (isteğe bağlı) Vite’nin SaaS proxy hedefi; varsayılan http://127.0.0.1:4000

VITE_API_BASE=http://localhost:8000
NEXT_PUBLIC_API_URL=
VITE_SAAS_API_BASE=
VITE_SAAS_PROXY_TARGET=http://127.0.0.1:4000

# Kamuya açık site kökü — canonical URL, hreflang ve JSON-LD için.
# Üretimde mutlaka ayarlayın (örn. https://pdfplatform.app); boşsa window.location.origin kullanılır.
VITE_PUBLIC_SITE_URL=

# Google Analytics 4 — Measurement ID (örn. G-ABC123XYZ). Gerçek ID gelene kadar placeholder bırakılabilir (yüklenmez).
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Yerel SPA bakım kaplaması: "true" iken bu makinede oluşturulan bundle ana sayfayı bakım olarak gösterir; üretimi etkilemez.
VITE_MAINTENANCE_MODE=false

# Sentry hata izleme — https://sentry.io adresinden ücretsiz DSN alın.
# Boş bırakılırsa Sentry devre dışı kalır (geliştirme ortamı için uygundur).
# VITE_SENTRY_DSN=https://your-key@oXXXXXX.ingest.sentry.io/XXXXXXX
